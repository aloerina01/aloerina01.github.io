exports[`HTML Structure Snapshot Tests > Page structure snapshots > should match snapshot: blog/2025-08-04-1.html 1`] = `"<!DOCTYPE html><html><head><meta charset="utf-8"><meta http-equiv="X-UA-Compatible" content="IE=edge"><meta name="viewport" content="width=device-width, initial-scale=1"><title>議論を“立て直す”ときに使える、力点と作用点を効かせるファシリテーション</title><meta name="description" content="会議で「論点がかみ合わない」「発言は出ているのにまとまらない」と感じたことはありませんか？ そんなとき、議論の構造を「テコの原理」になぞらえて捉え直すことで、力点と作用点のズレに気づき、議論を立て直すヒントが見えてきます。"><meta name="author" content="aloerina"><meta name="copyright" content="&copy; aloerina {{YEAR}}"><meta name="google-site-verification" content="FEbLKzXnOoXdy4JCrf6UntpqxWuuK8umvUEhILj8IU8" /><link rel="manifest" href="/manifest.json"><!-- External libraries --><link rel="stylesheet" as="style" href="/css/prism.css"><!-- Favicon and other icons (made with http://www.favicon-generator.org/) --><link rel="shortcut icon" href="/assets/icons/favicon.ico" type="image/x-icon"><link rel="icon" href="/assets/icons/favicon.ico" type="image/x-icon"><link rel="apple-touch-icon" sizes="109x109" href="/assets/icons/favicon 1ldpi.png"><link rel="apple-touch-icon" sizes="146x146" href="/assets/icons/favicon 1mdpi.png"><link rel="apple-touch-icon" sizes="218x218" href="/assets/icons/favicon 1hdpi.png"><link rel="apple-touch-icon" sizes="290x290" href="/assets/icons/favicon 1xhdpi.png"><link rel="apple-touch-icon" sizes="435x435" href="/assets/icons/favicon 1xxhdpi.png"><link rel="apple-touch-icon" sizes="580x580" href="/assets/icons/favicon 1xxxhdpi.png"><meta name="msapplication-TileColor" content="#ffffff"><meta name="msapplication-TileImage" content="/assets/icons/favicon 1mdpi.png"><meta name="theme-color" content="#546E7A"><meta name="apple-mobile-web-app-title" content="mf-code"><meta name="apple-mobile-web-app-capable" content="yes"><meta name="apple-mobile-web-app-status-bar-style" content="black"><!-- Facebook OGP cards --><meta property="og:description" content="会議で「論点がかみ合わない」「発言は出ているのにまとまらない」と感じたことはありませんか？ そんなとき、議論の構造を「テコの原理」になぞらえて捉え直すことで、力点と作用点のズレに気づき、議論を立て直すヒントが見えてきます。" /><meta property="og:url" content="{{BASE_URL}}/blog/2025-08-04-1" /><meta property="og:site_name" content="Feel and Code" /><meta property="og:title" content="議論を“立て直す”ときに使える、力点と作用点を効かせるファシリテーション" /><meta property="og:type" content="website" /><meta property="og:image" content="{{BASE_URL}}/assets/ogp/2025-08-04-1.jpg" /><meta property="og:image:type" content="image/png" /><meta property="og:image:width" content="612" /><meta property="og:image:height" content="605" /><!-- Twitter: card tags --><meta name="twitter:card" content="summary_large_image"><meta name="twitter:title" content="議論を“立て直す”ときに使える、力点と作用点を効かせるファシリテーション"><meta name="twitter:description" content="会議で「論点がかみ合わない」「発言は出ているのにまとまらない」と感じたことはありませんか？ そんなとき、議論の構造を「テコの原理」になぞらえて捉え直すことで、力点と作用点のズレに気づき、議論を立て直すヒントが見えてきます。"><meta name="twitter:image" content="{{BASE_URL}}/assets/ogp/2025-08-04-1.jpg"><meta name="twitter:url" content="{{BASE_URL}}/blog/2025-08-04-1"><!-- Site styles --><link rel="stylesheet" href="/css/main.css"><link rel="canonical" href="{{BASE_URL}}/blog/2025-08-04-1"><link rel="alternate" type="application/rss+xml" title="Feel and Code" href="{{BASE_URL}}/feed.xml" /><meta name="algolia-site-verification" content="72D549DE860CC566" /><script> (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){ (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o), m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m) })(window,document,'script','//www.google-analytics.com/analytics.js','ga'); ga('create', 'UA-39630080-4', 'auto'); ga('require', 'linkid'); ga('send', 'pageview', { 'page': '{{GA_PAGE}}', 'title': '{{GA_TITLE}}' }); </script><script src="/dist/prism.js" defer></script></head><body><header class="navigation" role="banner"><div class="navigation-wrapper"><a href="/" class="logo"><picture><source src="/assets/logo.webp" type="image/webp"><img src